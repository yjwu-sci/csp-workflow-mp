# Sensitive data
.env
*.key
secrets/

# MP API responses with potential metadata
mp_raw_*.json

# macOS metadata
.DS_Store
**/.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Large data files (tracked separately or via symlink)
data/
data/MP/cifs/
data/MP/descriptors.npy
data/MP/metadata.csv
data/MP/metadata_with_descriptors.csv

# Trained models (tracked via Zenodo, not Git)
csp_workflow_mp/models/*.pkl
csp_workflow_mp/models/*.joblib

# Results (too large for Git; archived on Zenodo)
results/
results_*/

# Local backups from bug-fix / refactor cycles
*.bak

# Local archive directories (not for GitHub)
_archive_logs/
_archive/

# Temporary files
*.tmp
*.log

# Notebook execution artifacts (regenerated by the user)
predictions_demo/
notebooks/predictions_demo/
KTaO3_predicted.cif
notebooks/KTaO3_predicted.cif

# Local HTML previews of notebooks (only .ipynb should be committed)
notebooks/*.html

# Dev / verification scratch dirs
_verify_outputs/
_tmp_*/
_tmp_*.py
